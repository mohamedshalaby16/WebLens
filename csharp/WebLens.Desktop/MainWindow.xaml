<Window x:Class="WebLens.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WebLens — Web Intelligence Platform"
        Height="800" Width="1100"
        MinHeight="700" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0f172a">

    <Window.Resources>
        <!-- Base button style -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary blue button -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#2563eb"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1d4ed8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="#64748b"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1e293b"/>
                    <Setter Property="Foreground" Value="#475569"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- PDF button -->
        <Style x:Key="PdfButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#0d9488"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0f766e"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="#64748b"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section card style -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Section title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748b"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
         
        </Style>

        <!-- Label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#64748b"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="MinWidth" Value="130"/>
        </Style>

        <!-- Value style -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- URL Input -->
            <RowDefinition Height="*"/>
            <!-- Results -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0f172a" Padding="30,20,30,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="WebLens"
                               FontFamily="Segoe UI"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Web Intelligence &amp; Phishing Risk Platform"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#64748b"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Server status indicator -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="8" Height="8"
                             Fill="#ef4444"
                             Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Connecting..."
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Foreground="#64748b"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0"
                   Height="1"
                   Fill="#1e293b"
                   VerticalAlignment="Bottom"/>

        <!-- ── URL Input Bar ──────────────────────────────────── -->
        <Border Grid.Row="1" Background="#0f172a" Padding="30,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#1e293b"
                        CornerRadius="8"
                        Margin="0,0,10,0"
                        Padding="14,0">
                    <TextBox x:Name="UrlInput"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             Foreground="#e2e8f0"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             Height="42"
                             CaretBrush="White"
                             KeyDown="UrlInput_KeyDown">
                        <TextBox.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Border>

                <Button x:Name="AnalyzeButton"
                        Grid.Column="1"
                        Content="Analyze"
                        Style="{StaticResource PrimaryButton}"
                        Width="110"
                        Margin="0,0,8,0"
                        Click="AnalyzeButton_Click"/>

                <Button x:Name="ClearButton"
                        Grid.Column="2"
                        Content="Clear"
                        Style="{StaticResource SecondaryButton}"
                        Width="80"
                        Click="ClearButton_Click"/>
            </Grid>
        </Border>

        <!-- ── Results Panel ─────────────────────────────────── -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="30,0,30,20"
                      Background="#0f172a">

            <!-- Empty state -->
            <Grid x:Name="EmptyState">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,80,0,0">
                    <TextBlock Text="🔍"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>
                    <TextBlock Text="Enter a URL above to begin analysis"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               Foreground="#334155"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="WebLens will clone the page, analyze its content, and assess phishing risk"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#1e293b"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Loading state (hidden by default) -->
                <StackPanel x:Name="LoadingPanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,80,0,0">
                    <TextBlock x:Name="LoadingText"
                               Text="Cloning page..."
                               FontFamily="Segoe UI"
                               FontSize="16"
                               Foreground="#64748b"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <ProgressBar x:Name="LoadingBar"
                                 IsIndeterminate="True"
                                 Width="300"
                                 Height="4"
                                 Foreground="#2563eb"
                                 Background="#1e293b"/>
                </StackPanel>

                <!-- Results (hidden by default) -->
                <StackPanel x:Name="ResultsPanel"
                            Visibility="Collapsed"
                            Margin="0,20,0,0">

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,16">
                        <Button x:Name="ExportPdfButton"
                                Content="Export PDF"
                                Style="{StaticResource PdfButton}"
                                Margin="0,0,8,0"
                                Click="ExportPdfButton_Click"/>
                        <Button x:Name="ViewCloneButton"
                                Content="View Clone"
                                Style="{StaticResource SecondaryButton}"
                                Click="ViewCloneButton_Click"/>
                    </StackPanel>

                    <!-- Risk Score Banner -->
                    <Border x:Name="RiskBanner"
                            CornerRadius="10"
                            Padding="24,20"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PHISHING RISK SCORE"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#64748b"
                                           Margin="0,0,0,8"/>
                                <ProgressBar x:Name="RiskProgressBar"
                                             Height="8"
                                             Maximum="100"
                                             Value="0"
                                             Width="300"
                                             HorizontalAlignment="Left"
                                             Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="RiskScoreText"
                                               FontFamily="Segoe UI"
                                               FontSize="32"
                                               FontWeight="Bold"/>
                                    <TextBlock Text=" / 100"
                                               FontFamily="Segoe UI"
                                               FontSize="18"
                                               Foreground="#64748b"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,4"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    x:Name="VerdictBadge"
                                    CornerRadius="8"
                                    Padding="20,12"
                                    VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="VerdictIcon"
                                               FontSize="28"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="VerdictText"
                                               FontFamily="Segoe UI"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Clone Info -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="CLONE INFORMATION"
                                       Style="{StaticResource SectionTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Page Title" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="PageTitleText" Style="{StaticResource FieldValue}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Fetcher Used" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="FetcherText" Style="{StaticResource FieldValue}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Assets Downloaded" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AssetsText" Style="{StaticResource FieldValue}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Forms Found" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="FormsText" Style="{StaticResource FieldValue}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Links Found" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="LinksText" Style="{StaticResource FieldValue}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Assets Failed" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AssetsFailedText" Style="{StaticResource FieldValue}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Intelligence -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="PAGE INTELLIGENCE"
                                       Style="{StaticResource SectionTitle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Page Type" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="PageTypeText" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Technology Stack" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TechStackText" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="External Links" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="ExternalLinksText" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Internal Links" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="InternalLinksText" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Summary"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,6"/>
                                <Border Background="#0f172a"
                                        CornerRadius="6"
                                        Padding="14">
                                    <TextBlock x:Name="SummaryText"
                                               FontFamily="Segoe UI"
                                               FontSize="11"
                                               Foreground="#94a3b8"
                                               TextWrapping="Wrap"
                                               LineHeight="18"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Red Flags -->
                    <Border x:Name="RedFlagsCard"
                            Style="{StaticResource SectionCard}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="RED FLAGS DETECTED"
                                       Style="{StaticResource SectionTitle}"
                                       Foreground="#ef4444"/>
                            <ItemsControl x:Name="RedFlagsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1c0a0a"
                                                CornerRadius="6"
                                                Padding="12,8"
                                                Margin="0,0,0,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⚠  "
                                                           Foreground="#ef4444"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#fca5a5"
                                                           FontFamily="Segoe UI"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Explanation -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="ASSESSMENT EXPLANATION"
                                       Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="ExplanationText"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Foreground="#94a3b8"
                                       TextWrapping="Wrap"
                                       LineHeight="18"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ── Status Bar ─────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="#0a0f1a"
                Padding="30,8">
            <TextBlock x:Name="StatusBar"
                       Text="Ready"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Foreground="#334155"/>
        </Border>
    </Grid>
</Window>